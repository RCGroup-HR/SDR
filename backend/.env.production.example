# ========================================
# CONFIGURACIÓN DE PRODUCCIÓN - SDR WEB
# ========================================
#
# ⚠️ IMPORTANTE: NO uses este archivo directamente
# Las variables deben configurarse en el sistema operativo del VPS
#
# En Linux/Ubuntu, añadir a /etc/environment o usar PM2 ecosystem.config.js
# ========================================

# Entorno
NODE_ENV=production

# Servidor
PORT=3001

# Base de Datos
# ⚠️ NUNCA uses 'root' en producción
# Crea un usuario específico con permisos limitados
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=sdr_app
DB_PASSWORD=GENERA_PASSWORD_FUERTE_AQUI
DB_NAME=sdr_web

# JWT Configuration
# ⚠️ GENERA UN SECRET ÚNICO Y SEGURO
# Comando: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRET_DE_64_BYTES_GENERADO_CON_CRYPTO
JWT_EXPIRES_IN=24h

# Frontend URL para CORS
FRONTEND_URL=https://estadísticasdeldomino.lat

# ========================================
# INSTRUCCIONES PARA CONFIGURAR EN VPS
# ========================================
#
# Opción 1: Variables de entorno del sistema
# -------------------------------------------
# sudo nano /etc/environment
# Añadir todas las variables arriba
# Reiniciar: sudo reboot
#
# Opción 2: PM2 ecosystem.config.js (RECOMENDADO)
# ------------------------------------------------
# Ver archivo: ecosystem.config.js.example
#
# Opción 3: .env con permisos restringidos (menos seguro)
# --------------------------------------------------------
# cp .env.production.example .env.production
# chmod 600 .env.production
# chown tu_usuario:tu_usuario .env.production
#
# ⚠️ NUNCA subas archivos .env a Git
# ========================================
